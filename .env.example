# 複製為 .env.local 後填入（勿提交 .env.local）
# cp .env.example .env.local

# --- Supabase PostgreSQL（必填）---
# Dashboard → Project Settings → Database → Connect → Session pooler（或 Transaction）
#
# Session pooler（URI，port 常為 5432）範例：
# postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
#
# Transaction pooler 常見為 port 6543，同樣可設為 DATABASE_URL。
#
# npm run db:push 會讀取 .env 與 .env.local
DATABASE_URL=

# BallDontLie NBA API
BALLDONTLIE_API_KEY=

# 登入 Session（正式環境請用長隨機字串，至少 16 字元）
SESSION_SECRET=

# API seasons[] 參數
NBA_SEASON=2025

# 季後賽輪次分界（可選）
# PLAYOFF_R1_END=2026-05-06
# PLAYOFF_R2_END=2026-05-21
# PLAYOFF_R3_END=2026-06-08
