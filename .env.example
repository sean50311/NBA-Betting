# 複製此檔為 .env.local 後填入真實值（勿提交 .env.local）
# cp .env.example .env.local

# BallDontLie NBA API：https://app.balldontlie.io/ — 請求標頭為 Authorization: <你的 key>
BALLDONTLIE_API_KEY=

# 登入 Session 簽章用；正式環境請用長隨機字串（至少 16 字元）。開發未設時會用內建預設。
SESSION_SECRET=

# API 的 seasons[] 參數，例如 2025 代表 2025–26 球季（依官方文件為準）
NBA_SEASON=2025

# SQLite 檔路徑（預設為專案目錄下 data/app.db）
# DATABASE_PATH=./data/app.db

# 季後賽輪次分界（比賽日 YYYY-MM-DD），用於對應賠率 1 / 1.5 / 2 / 3
# PLAYOFF_R1_END=2026-05-06
# PLAYOFF_R2_END=2026-05-21
# PLAYOFF_R3_END=2026-06-08
